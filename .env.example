# 디스코드 봇 토큰 (Discord Developer Portal에서 발급)
# https://discord.com/developers/applications
DISCORD_TOKEN=your_bot_token_here

# 봇이 등록될 서버 ID (선택, 글로벌 명령은 배포 시 시간이 걸림)
# 개발 시에는 GUILD_ID를 넣으면 해당 서버에만 명령이 즉시 반영됩니다.
GUILD_ID=

# /협곡 시 멘션할 역할 ID (선택, 비우면 멘션 없음)
# 역할 ID: 서버 설정 → 역할 → 해당 역할 우클릭 → ID 복사 (개발자 모드 필요)
ROLE_ID_COOP=

# /증바람 시 멘션할 역할 ID (선택, 비우면 멘션 없음)
ROLE_ID_ARAM=
